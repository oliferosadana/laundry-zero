<%
const itemRows = (order.items || []).map((item) => {
  const qty = `${item.quantity} ${item.unit}`.trim();
  return `
    <div class="thermal-item-row">
      <div>
        <div class="thermal-item-name">${item.serviceName}</div>
        <div class="thermal-item-meta">${qty} × Rp ${Number(item.unitPrice || 0).toLocaleString('id-ID')}</div>
      </div>
      <div class="thermal-item-price">Rp ${Number(item.subtotal || 0).toLocaleString('id-ID')}</div>
    </div>
  `;
}).join('');
const body = `
<section class="hero no-print">
  <div><h2>Nota Laundry</h2><p>${order.invoiceNumber}</p></div>
  <div class="actions">
    <a href="/orders" class="btn btn-secondary">Kembali</a>
    <button onclick="window.print()" class="btn btn-secondary">Cetak (Browser)</button>
    <button id="bluetoothPrintBtn" class="btn btn-primary">Cetak via Bluetooth</button>
  </div>
</section>
<section class="thermal-receipt-wrap">
  <article class="panel receipt thermal-receipt">
    <header class="thermal-header text-center">
      <h2>${settings.storeName || appName}</h2>
      <p>${settings.address || '-'}<br/>${settings.phone || '-'}</p>
      <div class="thermal-divider"></div>
      <p class="thermal-invoice"><strong>${order.invoiceNumber}</strong></p>
    </header>

    <section class="thermal-meta">
      <div class="thermal-meta-row"><span>Tanggal</span><span>${dayjs(order.createdAt).format('DD/MM/YYYY HH:mm')}</span></div>
      <div class="thermal-meta-row"><span>Pelanggan</span><span>${order.customerName}</span></div>
      <div class="thermal-meta-row"><span>No HP</span><span>${order.customerPhone || '-'}</span></div>
      <div class="thermal-meta-row"><span>Status</span><span>${order.status}</span></div>
      <div class="thermal-meta-row"><span>Bayar</span><span>${order.paymentStatus}</span></div>
      <div class="thermal-meta-row"><span>Estimasi</span><span>${order.estimatedReadyAt ? dayjs(order.estimatedReadyAt).format('DD/MM HH:mm') : '-'}</span></div>
    </section>

    <div class="thermal-divider"></div>

    <section class="thermal-items">
      ${itemRows}
    </section>

    <div class="thermal-divider"></div>

    <section class="thermal-total-block">
      <div class="thermal-meta-row total-row"><span>Total</span><span>Rp ${Number(order.totalAmount || 0).toLocaleString('id-ID')}</span></div>
    </section>

    ${order.notes ? `
      <div class="thermal-divider"></div>
      <section class="thermal-notes">
        <strong>Catatan</strong>
        <p>${order.notes}</p>
      </section>
    ` : ''}

    <div class="thermal-divider"></div>

    <section class="thermal-qr-section">
      <p class="muted text-center">Scan QR ini untuk update status oleh staff</p>
      <div class="thermal-qr-box">
        <img src="${qrImageUrl}" alt="QR order ${order.invoiceNumber}" />
      </div>
      <p class="thermal-scan-url">${scanUrl}</p>
    </section>

    <footer class="thermal-footer text-center">
      <div class="thermal-divider"></div>
      <p>${settings.receiptFooter || ''}</p>
    </footer>
  </article>

  <section class="panel-soft qr-section mt-16 no-print">
    <div>
      <h3>QR Staff Scanner</h3>
      <p class="muted">Printer thermal 80mm akan memakai layout ringkas. Bagian ini hanya untuk tampilan layar/admin.</p>
      <div class="actions"><a href="/scanner" class="btn btn-secondary">Buka halaman scanner</a><a href="${scanUrl}" class="btn btn-secondary">Buka link scan order</a></div>
    </div>
    <div class="qr-box">
      <img src="${qrImageUrl}" alt="QR order ${order.invoiceNumber}" />
    </div>
  </section>
</section>
`;
`;\n    85|%><%- include('layout', { pageTitle: 'Nota', body }) %>\n    86|<script>\n    87|  // Web Bluetooth API for thermal printer\n    88|  document.getElementById('bluetoothPrintBtn').addEventListener('click', async () => {\n    89|    if (!('bluetooth' in navigator)) {\n    90|      alert('Web Bluetooth API tidak didukung di browser ini. Gunakan Chrome/Edge dan aktifkan flag #enable-experimental-web-platform-features');\n    91|      return;\n    92|    }\n    93|    try {\n    94|      const device = await navigator.bluetooth.requestDevice({\n    95|        filters: [{ services: ['00001800-0000-1000-8000-00805f9b34fb'] }], // Generic Access Service\n    96|        optionalServices: ['00001801-0000-1000-8000-00805f9b34fb'] // Generic Attribute Service\n    97|      });\n    98|      \n    99|      const server = await device.gatt.connect();\n    100|      const service = await server.getPrimaryService('00001801-0000-1000-8000-00805f9b34fb');\n    101|      // Look for a characteristic that supports writing (common for printers)\n    102|      const characteristics = await service.getCharacteristics();\n    103|      let writeChar = null;\n    104|      for (const char of characteristics) {\n    105|        if (char.properties.write || char.properties.writeWithoutResponse) {\n    106|          writeChar = char;\n    107|          break;\n    107|        }\n    108|      }\n    109|      if (!writeChar) {\n    110|        alert('Tidak ditemukan karakteristik yang support escrita. Pastikan printer mendukung SPP atau UUID khusus.');\n    111|        return;\n    112|      }\n    113|      \n    114|      // Convert receipt content to ESC/POS commands (simplified)\n    115|      const text = generateThermalReceipt();\n    116|      const encoder = new TextEncoder();\n    117|      const data = encoder.encode(text);\n    118|      \n    119|      await writeChar.writeValue(data);\n    120|      alert('Nota berhasil dikirim ke printer via Bluetooth!');\n    121|    } catch (error) {\n    122|      console.error('Error:', error);\n    123|      alert('Gagal mencetak via Bluetooth: ' + error.message);\n    124|    }\n    125|  });\n    126|  \n    127|  function generateThermalReceipt() {\n    128|    // This should match the thermal-receipt content\n    129|    const lines = [];\n    130|    lines.push('${settings.storeName || appName}');\n    131|    lines.push('${settings.address || '-'}');\n    132|    lines.push('${settings.phone || '-'}');\n    133|    lines.push('--------------------');\n    134|    lines.push('Invoice: ${order.invoiceNumber}');\n    135|    lines.push('Tanggal: ${dayjs(order.createdAt).format('DD/MM/YYYY HH:mm')}');\n    136|    lines.push('Pelanggan: ${order.customerName}');\n    137|    lines.push('No HP: ${order.customerPhone || '-'}');\n    138|    lines.push('Status: ${order.status}');\n    139|    lines.push('Bayar: ${order.paymentStatus}');\n    140|    lines.push('Estimasi: ${order.estimatedReadyAt ? dayjs(order.estimatedReadyAt).format('DD/MM HH:mm') : '-'}');\n    141|    lines.push('--------------------');\n    142|    ${order.items && order.items.length > 0 ? `order.items.forEach(item => {\n    143|      const qty = `${item.quantity} ${item.unit}`.trim();\n    144|      lines.push(`${item.serviceName.padEnd(20)} ${qty}`);\n    145|      lines.push(`  Rp ${Number(item.unitPrice || 0).toLocaleString('id-ID')} x${item.quantity}`);\n    146|      lines.push(`  Rp ${Number(item.subtotal || 0).toLocaleString('id-ID')}`);\n    147|    });` : ''}\n    148|    lines.push('--------------------');\n    149|    lines.push(`Total: Rp ${Number(order.totalAmount || 0).toLocaleString('id-ID')}`);\n    150|    lines.push('');\n    151|    lines.push(${order.notes ? `''Catatan:''\n    152|    lines.push('${order.notes}');` : ''}\n    153|    lines.push('--------------------');\n    154|    lines.push('${settings.receiptFooter || ''}');\n    155|    lines.push('');\n    156|    lines.push('');\n    157|    // Add cut command (ESC/POS)\n    158|    lines.push(String.fromCharCode(0x1D, 0x56, 0x00)); // GS V 0\n    159|    return lines.join('\\n');\n    160|  }\n    161|</script>\n    86|%><%- include('layout', { pageTitle: 'Nota', body }) %>
