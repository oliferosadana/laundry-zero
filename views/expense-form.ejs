<%
const title = mode === 'edit' ? 'Edit Pengeluaran' : 'Tambah Pengeluaran';
const body = `
<section class="hero">
  <div><h2>${title}</h2><p>Catat biaya operasional laundry agar laba rugi lebih jelas.</p></div>
  <div class="actions"><a href="/expenses" class="btn btn-secondary">Kembali</a></div>
</section>
<section class="panel">
  ${error ? `<div class="error-box">${error}</div>` : ''}
  <form method="post" action="${formAction}" class="form-grid">
    <div class="grid-2">
      <label><span>Nama pengeluaran</span><input type="text" name="title" value="${values.title || ''}" required /></label>
      <label><span>Kategori</span><input type="text" name="category" value="${values.category || ''}" placeholder="Contoh: deterjen, listrik, gaji" required /></label>
    </div>
    <div class="grid-2">
      <label><span>Nominal</span><input type="number" min="0" step="100" name="amount" value="${values.amount || ''}" required /></label>
      <label><span>Tanggal & waktu</span><input type="datetime-local" name="spentAt" value="${values.spentAt || ''}" required /></label>
    </div>
    <label><span>Catatan</span><textarea name="notes">${values.notes || ''}</textarea></label>
    <div class="actions"><button type="submit" class="btn btn-primary">${mode === 'edit' ? 'Simpan perubahan' : 'Simpan pengeluaran'}</button></div>
  </form>
</section>
`;
%><%- include('layout', { pageTitle: title, body }) %>
