<%
const body = `
<section class="hero">
  <div>
    <h2>Dashboard</h2>
    <p>Ringkasan operasional, pengeluaran, dan laba bulan berjalan.</p>
  </div>
  <form method="post" action="/logout"><button class="btn btn-secondary" type="submit">Logout</button></form>
</section>
<section class="stats stats-6">
  <article class="card"><h3>Total order</h3><p>${stats.totalOrders}</p></article>
  <article class="card"><h3>Order aktif</h3><p>${stats.activeOrders}</p></article>
  <article class="card"><h3>Selesai belum diambil</h3><p>${stats.pendingPickup}</p></article>
  <article class="card"><h3>Omzet hari ini</h3><p>Rp ${Number(stats.todayRevenue || 0).toLocaleString('id-ID')}</p></article>
  <article class="card"><h3>Pengeluaran bulan ini</h3><p>Rp ${Number(stats.monthExpenses || 0).toLocaleString('id-ID')}</p></article>
  <article class="card ${stats.monthProfit >= 0 ? 'profit-card' : 'loss-card'}"><h3>Laba bulan ini</h3><p>Rp ${Number(stats.monthProfit || 0).toLocaleString('id-ID')}</p></article>
</section>
<section class="panel">
  <div class="hero">
    <div><h2>Aksi cepat</h2><p>Mulai operasional harian dari sini.</p></div>
    <div class="actions">
      <a href="/orders/new" class="btn btn-primary">Order baru</a>
      <a href="/customers/new" class="btn btn-secondary">Tambah pelanggan</a>
      <a href="/services/new" class="btn btn-secondary">Tambah layanan</a>
      <a href="/expenses/new" class="btn btn-secondary">Tambah pengeluaran</a>
      <a href="/reports" class="btn btn-secondary">Lihat laporan</a>
    </div>
  </div>
</section>
<section class="dashboard-split">
  <section class="panel">
    <div class="hero"><div><h2>Order terbaru</h2><p>Daftar order paling akhir masuk dan update status cepat.</p></div></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Invoice</th><th>Pelanggan</th><th>Status</th><th>Bayar</th><th>Total</th><th>Aksi</th></tr></thead>
        <tbody>
          ${recentOrders.length ? recentOrders.map((order) => `
            <tr>
              <td>${order.invoiceNumber}</td>
              <td>${order.customerName}</td>
              <td>
                <form method="post" action="/orders/${order.id}/status" class="inline-status-form">
                  <select name="status" onchange="this.form.submit()">
                    ${statuses.map((status) => `<option value="${status}" ${order.status === status ? 'selected' : ''}>${status}</option>`).join('')}
                  </select>
                </form>
              </td>
              <td><span class="badge">${order.paymentStatus}</span></td>
              <td>Rp ${Number(order.totalAmount || 0).toLocaleString('id-ID')}</td>
              <td><div class="actions"><a href="/orders/${order.id}" class="btn btn-secondary">Detail</a><a href="/orders/${order.id}/receipt" class="btn btn-secondary">Nota</a></div></td>
            </tr>
          `).join('') : '<tr><td colspan="6" class="muted">Belum ada order.</td></tr>'}
        </tbody>
      </table>
    </div>
  </section>
  <section class="panel">
    <div class="hero"><div><h2>Pengeluaran terbaru</h2><p>Biaya operasional terbaru yang sudah dicatat.</p></div></div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Tanggal</th><th>Nama</th><th>Kategori</th><th>Nominal</th></tr></thead>
        <tbody>
          ${recentExpenses.length ? recentExpenses.map((item) => `
            <tr>
              <td>${dayjs(item.spentAt).format('DD/MM HH:mm')}</td>
              <td>${item.title}</td>
              <td>${item.category}</td>
              <td>Rp ${Number(item.amount || 0).toLocaleString('id-ID')}</td>
            </tr>
          `).join('') : '<tr><td colspan="4" class="muted">Belum ada pengeluaran.</td></tr>'}
        </tbody>
      </table>
    </div>
  </section>
</section>
`;
%><%- include('layout', { pageTitle: 'Dashboard', body }) %>
