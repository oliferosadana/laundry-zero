<%
const itemRows = (order.items || []).map((item) => `
  <tr>
    <td>${item.serviceName}</td>
    <td>${item.quantity} ${item.unit}</td>
    <td>Rp ${Number(item.unitPrice || 0).toLocaleString('id-ID')}</td>
    <td>Rp ${Number(item.subtotal || 0).toLocaleString('id-ID')}</td>
  </tr>
`).join('');
const body = `
<section class="hero">
  <div>
    <h2>Detail Order</h2>
    <p>${order.invoiceNumber} • ${dayjs(order.createdAt).format('DD MMM YYYY HH:mm')}</p>
  </div>
  <div class="actions">
    <a href="/orders" class="btn btn-secondary">Kembali</a>
    <a href="/orders/${order.id}/edit" class="btn btn-secondary">Edit</a>
    <a href="/orders/${order.id}/receipt" class="btn btn-primary">Lihat nota</a>
  </div>
</section>
<section class="detail-grid">
  <article class="card compact-card">
    <h3>Pelanggan</h3>
    <p><strong>${order.customerName}</strong></p>
    <p class="muted">${order.customerPhone || '-'}</p>
  </article>
  <article class="card compact-card">
    <h3>Status order</h3>
    <form method="post" action="/orders/${order.id}/status" class="form-grid">
      <select name="status">
        ${statuses.map((status) => `<option value="${status}" ${order.status === status ? 'selected' : ''}>${status}</option>`).join('')}
      </select>
      <button type="submit" class="btn btn-secondary">Update status</button>
    </form>
  </article>
  <article class="card compact-card">
    <h3>Pembayaran</h3>
    <p><span class="badge">${order.paymentStatus}</span></p>
    <p class="muted">Estimasi selesai: ${order.estimatedReadyAt ? dayjs(order.estimatedReadyAt).format('DD MMM YYYY HH:mm') : '-'}</p>
  </article>
</section>
<section class="panel">
  <div class="table-wrap">
    <table>
      <thead><tr><th>Layanan</th><th>Qty</th><th>Harga</th><th>Subtotal</th></tr></thead>
      <tbody>${itemRows}</tbody>
    </table>
  </div>
  <div class="detail-summary">
    <div>
      <strong>Catatan</strong>
      <p class="muted">${order.notes || '-'}</p>
    </div>
    <div class="text-right">
      <strong>Total</strong>
      <p class="price-lg">Rp ${Number(order.totalAmount || 0).toLocaleString('id-ID')}</p>
    </div>
  </div>
</section>
`;
%><%- include('layout', { pageTitle: 'Detail Order', body }) %>
